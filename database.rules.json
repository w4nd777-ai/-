{
  "rules": {
    "cms-v3": {
      ".read": "auth != null",
      "$roomCode": {
        ".write": "auth != null",
        "students": {
          ".indexOn": ["sid", "cls", "email"]
        },
        "submissions": {
          ".indexOn": ["studentId", "assignmentId", "ts"]
        },
        "attendance": {
          ".indexOn": ["studentId", "date"]
        },
        "messages": {
          ".indexOn": ["ts"],
          "$msgId": {
            ".validate": "newData.hasChildren(['id','fromId','ts']) && (!newData.child('text').exists() || (newData.child('text').isString() && newData.child('text').val().length <= 4000))"
          }
        },
        "behavior": {
          ".indexOn": ["studentId", "ts"]
        },
        "leaves": {
          ".indexOn": ["studentId", "date"]
        },
        "pending": {
          "$pid": {
            ".validate": "newData.hasChildren(['id','role','ts']) && (newData.child('role').val() === 'student' || newData.child('role').val() === 'teacher') && (!newData.child('name').exists() || (newData.child('name').isString() && newData.child('name').val().length <= 100))"
          }
        },
        "attachments": {
          "$attKey": {
            ".validate": "!newData.exists() || newData.isString() || newData.hasChild('dataUri') || newData.hasChild('meta') || newData.hasChild('data')"
          }
        },
        "settings": {
          "roomPinHash": {
            ".validate": "newData.val() === null || (newData.isString() && newData.val().length >= 8 && newData.val().length <= 256)"
          }
        },
        "_errors": {
          "$errId": {
            ".validate": "newData.hasChildren(['type','msg']) && newData.child('msg').isString() && newData.child('msg').val().length < 1000"
          }
        },
        "_graveyard": {
          ".write": "auth != null"
        }
      },
      "google_users": {
        "$emailKey": {
          ".read": "auth != null && auth.token.email != null && auth.token.email.toLowerCase().replace('.', '_').replace('@', '_') == $emailKey",
          ".write": "auth != null && auth.token.email != null && auth.token.email.toLowerCase().replace('.', '_').replace('@', '_') == $emailKey"
        }
      }
    }
  }
}
